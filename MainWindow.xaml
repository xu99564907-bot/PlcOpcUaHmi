eLeftButtonUp="StartDeviceButton_PreviewMouseLeftButtonUp" MouseLeave="StartDeviceButton_PreviewMouseLeftButtonUp" Background="#2563EB" Foreground="White" BorderBrush="#60A5FA" BorderThickness="2" Padding="12,8"/><Button Content="立即停止" Command="{Binding StopDeviceCommand}" Style="{StaticResource EmergencyStopButtonStyle}"/><Button Content="报警复位" Command="{Binding ResetAlarmFromHomeCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="12,8"/></WrapPanel><ProgressBar Value="{Binding StartHoldProgress}" Maximum="100" Height="10" Margin="0,8,0,0" Foreground="#60A5FA" Background="#1E293B"/><TextBlock Text="启动按钮需长按 1 秒生效；停止按钮点击即刻生效。" Foreground="#94A3B8" Margin="0,8,0,0"/><UniformGrid Columns="3" Margin="0,8,0,0"><Border Background="#0F172A" CornerRadius="8" Padding="10,6" Margin="0,0,6,0"><StackPanel><TextBlock Text="模式就绪" Foreground="#94A3B8" FontSize="12"/><TextBlock Text="{Binding StartModeReady}" Foreground="#22C55E" FontWeight="Bold"/></StackPanel></Border><Border Background="#0F172A" CornerRadius="8" Padding="10,6" Margin="3,0"><StackPanel><TextBlock Text="报警清除" Foreground="#94A3B8" FontSize="12"/><TextBlock Text="{Binding StartAlarmReady}" Foreground="#22C55E" FontWeight="Bold"/></StackPanel></Border><Border Background="#0F172A" CornerRadius="8" Padding="10,6" Margin="6,0,0,0"><StackPanel><TextBlock Text="联锁就绪" Foreground="#94A3B8" FontSize="12"/><TextBlock Text="{Binding StartInterlockReady}" Foreground="#22C55E" FontWeight="Bold"/></StackPanel></Border></UniformGrid><Border Background="#1E3A8A" CornerRadius="8" Padding="10,6" Margin="0,8,0,0"><TextBlock Text="{Binding RunModeSummary, StringFormat=当前运行模式：{0}}" Foreground="White"/></Border><Border Background="#065F46" CornerRadius="8" Padding="10,6" Margin="0,6,0,0"><TextBlock Text="{Binding StartStopSummary}" Foreground="White"/></Border></StackPanel></Border>
                                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="14"><StackPanel><TextBlock Text="重点报警" Foreground="#94A3B8"/><TextBlock Text="{Binding FocusAlarmHint}" FontSize="18" FontWeight="Bold" Foreground="#FCA5A5" TextWrapping="Wrap"/><TextBlock Text="{Binding EstimatedDowntimeMinutes, StringFormat=预计停机：{0:F1} min}" Foreground="#FCD34D" Margin="0,10,0,4"/><TextBlock Text="{Binding EstimatedProductionLoss, StringFormat=预计影响产量：{0}}" Foreground="#FCA5A5"/><TextBlock Text="依据报警次数、当前激活状态与影响估算自动排序" Foreground="#CBD5E1" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                        </Grid>
                                        <UniformGrid Grid.Row="2" Columns="4">
                                            <Border Background="#1D4ED8" CornerRadius="10" Padding="16" Margin="6"><StackPanel><TextBlock Text="电机" Foreground="White" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding MotorStatusText}" Foreground="#DBEAFE" Margin="0,6,0,0"/><ProgressBar Value="70" Maximum="100" Height="8" Margin="0,10,0,0" Background="#1E3A8A" Foreground="#BFDBFE"/><TextBlock Text="具备运行 / 故障复位占位" Foreground="#BFDBFE" Margin="0,10,0,0" FontSize="12"/></StackPanel></Border>
                                            <Border Background="#059669" CornerRadius="10" Padding="16" Margin="6"><StackPanel><TextBlock Text="气缸" Foreground="White" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding CylinderStatusText}" Foreground="#D1FAE5" Margin="0,6,0,0"/><TextBlock Text="前到位 / 后到位实时反馈" Foreground="#A7F3D0" Margin="0,10,0,0" FontSize="12"/></StackPanel></Border>
