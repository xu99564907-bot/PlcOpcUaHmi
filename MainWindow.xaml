                    </Border>
                    <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PLC：" Foreground="#1D4ED8" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CommunicationStatus}" Foreground="#1D4ED8" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding SystemMessage}" Foreground="#0F172A" VerticalAlignment="Center"/>
                </WrapPanel>
                    <TextBlock DockPanel.Dock="Right" Text="C# / WPF / OPC UA / HMI Designer" Foreground="#64748B" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>








