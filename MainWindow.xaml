                                    <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,8,8" Visibility="{Binding IsManualAxisPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="轴单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="--" Foreground="#64748B" Margin="0,8,0,12"/><WrapPanel><Button Content="轴使能" Command="{Binding ToggleAxisEnableCommand}" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="报警复位" Command="{Binding AxisAlarmResetCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,8"/></WrapPanel><WrapPanel Margin="0,4,0,8"><TextBlock Text="Jog距离" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Width="80" Text="{Binding AxisJogDistance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/><Button Content="Jog-" Command="{Binding JogAxisNegativeCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="14,8" Margin="0,0,8,0"/><Button Content="Jog+" Command="{Binding JogAxisPositiveCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="14,8"/></WrapPanel><WrapPanel Margin="0,0,0,8"><TextBlock Text="目标位置" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Width="100" Text="{Binding AxisTargetPosition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/><Button Content="定位移动" Command="{Binding MoveAxisToTargetCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="14,8" Margin="0,0,8,0"/><Button Content="回零" Command="{Binding MoveAxisHomeCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="14,8"/></WrapPanel></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="8,0,0,8" Visibility="{Binding IsManualRobotPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="机械手单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="--" Foreground="#64748B" Margin="0,8,0,12"/><WrapPanel><Button Content="机械手 启停" Command="{Binding ToggleDeviceCommand}" CommandParameter="Robot_Run" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="暂停" Command="{Binding PauseRobotCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,8"/><Button Content="复位" Command="{Binding ResetRobotCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,8"/></WrapPanel></StackPanel></Border>
                                </UniformGrid>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Visibility="{Binding IsManualStopperPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="挡停单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/><WrapPanel Margin="0,8,0,0"><Button Content="挡停 升降" Command="{Binding ToggleDeviceCommand}" CommandParameter="Stopper_Up" Style="{StaticResource PrimaryButtonStyle}"/></WrapPanel></StackPanel></Border>
