                                                            </Style>
                                                        </TreeView.ItemContainerStyle>
                                                        <TreeView.Resources>
                                                            <HierarchicalDataTemplate DataType="{x:Type model:OpcUaBrowseNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#0F172A"/>
                                                                    <TextBlock Text="  " />
                                                                    <TextBlock Text="{Binding NodeClass}" Foreground="#64748B"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                        </TreeView.Resources>
                                                    </TreeView>
                                                </Border>
                                                <Border Grid.Column="1" Margin="0,12,12,12" Background="#FFFFFF" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="节点详情" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                                                        <TextBlock Text="显示名" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaBrowseNode.DisplayName}" Foreground="White" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                        <TextBlock Text="NodeId" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaBrowseNode.NodeId}" Foreground="#BFDBFE" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                        <TextBlock Text="节点类型" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaBrowseNode.NodeClass}" Foreground="White" Margin="0,4,0,10"/>
                                                        <TextBlock Text="数据类型" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaBrowseNode.DataType}" Foreground="White" Margin="0,4,0,10"/>
                                                        <TextBlock Text="当前值" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaNodeValue}" Foreground="#86EFAC" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                        <TextBlock Text="状态" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaNodeStatus}" Foreground="White" Margin="0,4,0,10"/>
                                                        <TextBlock Text="时间戳" Foreground="#94A3B8"/>
                                                        <TextBlock Text="{Binding SelectedOpcUaNodeTimestamp}" Foreground="White" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Grid Visibility="{Binding IsMonitorProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="240"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding SelectedFlowSummary}" Foreground="#93C5FD" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Margin="0,0,0,10">
                                                <TextBlock Text="主流程步号 Trace" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock DockPanel.Dock="Right" Text="横轴：时间 / 纵轴：主流程步号" Foreground="#94A3B8"/>
                                            </DockPanel>
                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding ProgramMonitorTraceLatestText}" Foreground="#93C5FD" FontWeight="Bold"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ProgramMonitorTraceWindowText}" Foreground="#94A3B8"/>
                                                </DockPanel>
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Margin="0,6,10,24">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding ProgramMonitorTraceAxisTopLabel}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Top"/>
                                                        <TextBlock Grid.Row="1" Text="{Binding ProgramMonitorTraceAxisMidHighLabel}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="{Binding ProgramMonitorTraceAxisMidLowLabel}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="3" Text="{Binding ProgramMonitorTraceAxisBottomLabel}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Bottom"/>
                                                    </Grid>
                                                    <Grid Grid.Column="1">
                                                        <Border x:Name="ProgramTraceChartHost"
                                                                Background="#111827"
                                                                CornerRadius="8"
                                                                MouseMove="ProgramTraceChartHost_MouseMove"
                                                                MouseLeave="ProgramTraceChartHost_MouseLeave"
                                                                MouseLeftButtonDown="ProgramTraceChartHost_MouseLeftButtonDown"
                                                                MouseLeftButtonUp="ProgramTraceChartHost_MouseLeftButtonUp"
                                                                MouseRightButtonDown="ProgramTraceChartHost_MouseRightButtonDown"
                                                                MouseWheel="ProgramTraceChartHost_MouseWheel">
                                                            <Grid Margin="12">
                                                                <Rectangle Fill="#111827" RadiusX="8" RadiusY="8"/>
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Border Grid.Row="0" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="1" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="2" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="3" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                </Grid>
                                                                <Path Data="{Binding ProgramMonitorMainFlowTracePath}" Stroke="#60A5FA" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine1, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Path Data="{Binding ProgramMonitorSubFlow2TracePath}" Stroke="#F59E0B" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine2, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Path Data="{Binding ProgramMonitorSubFlow3TracePath}" Stroke="#22C55E" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine3, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Canvas>
                                                                    <Line x:Name="ProgramTraceHoverXLine" Visibility="Collapsed" Stroke="#64748B" StrokeThickness="1" StrokeDashArray="3,3" Y1="0" Y2="400"/>
                                                                    <Line x:Name="ProgramTraceHoverYLine" Visibility="Collapsed" Stroke="#64748B" StrokeThickness="1" StrokeDashArray="3,3" X1="0" X2="400"/>
                                                                    <Line x:Name="ProgramTraceCursorALine" Visibility="Collapsed" Stroke="#F59E0B" StrokeThickness="2" Y1="0" Y2="400"/>
                                                                    <Line x:Name="ProgramTraceCursorBLine" Visibility="Collapsed" Stroke="#22C55E" StrokeThickness="2" Y1="0" Y2="400"/>
                                                                    <Rectangle x:Name="ProgramTraceSelectionRect" Visibility="Collapsed" Fill="#60A5FA" Opacity="0.25" Stroke="#93C5FD" StrokeThickness="1"/>
                                                                </Canvas>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                            <Grid Grid.Row="2" Margin="44,10,0,0">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProgramMonitorTraceStartLabel}" Foreground="#94A3B8"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ProgramMonitorTraceEndLabel}" Foreground="#94A3B8"/>
                                                    </Grid>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorCursorText}" Foreground="#CBD5E1"/>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                            <CheckBox Content="主线1" IsChecked="{Binding ProgramMonitorTraceShowLine1, Mode=TwoWay}" Foreground="#60A5FA" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                            <CheckBox Content="主线2" IsChecked="{Binding ProgramMonitorTraceShowLine2, Mode=TwoWay}" Foreground="#F59E0B" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                            <CheckBox Content="主线3" IsChecked="{Binding ProgramMonitorTraceShowLine3, Mode=TwoWay}" Foreground="#22C55E" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="光标跟随" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <ComboBox Width="90" ItemsSource="{Binding ProgramMonitorTraceFlowOptions}" SelectedItem="{Binding SelectedProgramMonitorTraceFlow, Mode=TwoWay}" Margin="0,0,16,0"/>
                                                            <TextBlock Text="Shift+左键拖拽缩放，双击复位" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                            <TextBlock Text="缩放" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <Slider Width="180" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ProgramMonitorTraceWindowMinutes, Mode=TwoWay}"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorCursorAText}" Foreground="#F59E0B" Margin="0,0,16,0"/>
                                                        <TextBlock Text="{Binding ProgramMonitorCursorBText}" Foreground="#22C55E" Margin="0,0,16,0"/>
                                                        <TextBlock Text="{Binding ProgramMonitorCursorDeltaText}" Foreground="#E2E8F0"/>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorTraceReplayText}" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                        <Button Content="暂停采样" Command="{Binding PauseProgramMonitorTraceCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="继续采样" Command="{Binding ResumeProgramMonitorTraceCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="历史回放" Command="{Binding EnterProgramMonitorTraceReplayCommand}" Background="#1D4ED8" Foreground="White" BorderBrush="#1D4ED8" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="回到实时" Command="{Binding ReturnProgramMonitorTraceToRealtimeCommand}" Background="#475569" Foreground="White" BorderBrush="#475569" Padding="10,4" Margin="0,0,16,0"/>
                                                        <Button Content="导出CSV" Command="{Binding ExportProgramMonitorTraceCsvCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,4" Margin="0,0,16,0"/>
                                                        <Button Content="保存会话" Command="{Binding SaveProgramMonitorTraceSessionCommand}" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="加载会话" Command="{Binding LoadProgramMonitorTraceSessionCommand}" Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" Padding="10,4" Margin="0,0,16,0"/>
                                                        <TextBlock Text="定位时间" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBox Width="120" Text="{Binding ProgramMonitorTraceLocateTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                                        <Button Content="定位" Command="{Binding LocateProgramMonitorTraceTimeCommand}" Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" Padding="10,4" Margin="0,0,16,0"/>
                                                        <TextBlock Text="回放" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <Slider Width="220" Minimum="0" Maximum="{Binding ProgramMonitorTraceReplayMaximum}" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ProgramMonitorTraceReplayPosition, Mode=TwoWay}" IsEnabled="{Binding HasProgramMonitorTraceHistory}"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding FlowStepsView}" AutoGenerateColumns="False" IsReadOnly="True" Background="#111827" Foreground="White" BorderBrush="#1F2937" Margin="0,0,0,12" RowStyle="{StaticResource HighlightRowStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="流程" Binding="{Binding FlowName}" Width="*"/>
                                            <DataGridTextColumn Header="步号" Binding="{Binding StepNo}" Width="*"/>
                                            <DataGridTextColumn Header="开始" Binding="{Binding StartTime}" Width="*"/>
                                            <DataGridTextColumn Header="结束" Binding="{Binding EndTime}" Width="*"/>
                                            <DataGridTextColumn Header="耗时(s)" Binding="{Binding DurationSeconds}" Width="*"/>
                                            <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*"/>
                                            <DataGridTextColumn Header="关联报警" Binding="{Binding RelatedAlarm}" Width="2*"/>
                                            <DataGridTemplateColumn Header="联动" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="看报警" Command="{Binding DataContext.JumpToAlarmByKeywordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RelatedAlarm}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <WrapPanel Grid.Row="3" Margin="0,0,0,8"><TextBlock Text="流程异常统计汇总 / 排行榜" Foreground="#FCD34D" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/><Button Content="跳转报警页" Command="{Binding JumpToAlarmPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,8,0"/><Button Content="跳转审计页" Command="{Binding JumpToAuditPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,8,0"/><Button Content="导出异常报告" Command="{Binding ExportFlowIssueReportCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6"/></WrapPanel>
                                    <DataGrid Grid.Row="4" ItemsSource="{Binding FlowIssueSummaries}" AutoGenerateColumns="False" IsReadOnly="True" Background="#111827" Foreground="White" BorderBrush="#1F2937" Height="150">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="*"/>
                                            <DataGridTextColumn Header="对象" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="指标" Binding="{Binding Metric}" Width="*"/>
                                            <DataGridTextColumn Header="结论" Binding="{Binding Conclusion}" Width="2*"/>
                                            <DataGridTemplateColumn Header="联动" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="看报警" Command="{Binding DataContext.JumpToAlarmByKeywordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Name}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="配方管理">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12" Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="配方管理" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                                <TextBlock Text="当前配方" Foreground="#94A3B8"/>
                                <ComboBox ItemsSource="{Binding Recipes}" SelectedValuePath="Name" DisplayMemberPath="Name" SelectedValue="{Binding SelectedRecipeName}" Margin="0,6,0,12"/>
                                <WrapPanel>
                                    <Button Content="加载到参数" Command="{Binding ApplyRecipeCommand}" CommandParameter="{Binding SelectedRecipeName}" Style="{StaticResource PrimaryButtonStyle}"/>
                                    <Button Content="新建配方" Command="{Binding CreateRecipeCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/>
                                    <Button Content="复制当前" Command="{Binding DuplicateRecipeCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/>
                                    <Button Content="删除当前" Command="{Binding DeleteRecipeCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="12,8" Margin="0,0,8,8"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <Button Content="用当前参数覆盖配方" Command="{Binding CaptureCurrentParametersToRecipeCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="12,8" Margin="0,0,8,8"/>
                                    <Button Content="加载配方文件" Command="{Binding LoadRecipesCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/>
                                    <Button Content="保存配方文件" Command="{Binding SaveRecipesCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="12,8"/>
                                </WrapPanel>
                                <TextBlock Text="说明：支持新建 / 复制 / 删除 / 保存当前参数快照 / 加载到参数页。" Foreground="#94A3B8" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="220"/>
                                </Grid.RowDefinitions>
                                <DataGrid ItemsSource="{Binding Recipes}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" Margin="0,0,0,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="配方名" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="产品编码" Binding="{Binding ProductCode}" Width="*"/>
                                        <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="*"/>
                                        <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*"/>
                                        <DataGridTextColumn Header="更新时间" Binding="{Binding UpdatedAt}" Width="*"/>
                                        <DataGridTextColumn Header="更新人" Binding="{Binding UpdatedBy}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Border Grid.Row="1" Background="#0B1324" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="当前配方参数快照" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <DataGrid ItemsSource="{Binding ActiveRecipeParameters}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="*"/>
                                                <DataGridTextColumn Header="参数名" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*"/>
                                                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="*"/>
                                                <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="手动画面">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12" Width="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentManualTitle}" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,0,12" Visibility="{Binding IsManualCylinderPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MinHeight="420">
                                            <ItemsControl ItemsSource="{Binding ManualCylinderBlockCards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type model:ManualCylinderBlockItem}">
                                                        <Border Style="{StaticResource CardBorderStyle}" Width="320" Padding="10" Margin="0,0,12,12">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <DockPanel LastChildFill="False">
                                                                    <StackPanel DockPanel.Dock="Left">
                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                                                        <TextBlock Text="{Binding StatusText}" Foreground="#2563EB" Margin="0,3,0,0" FontSize="13" FontWeight="SemiBold"/>
                                                                    </StackPanel>
                                                                    <Button DockPanel.Dock="Right" Content="参数设定" Click="OpenCylinderSettingsButton_Click" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="10,6"/>
                                                                </DockPanel>
                                                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,10,0,8">
                                                                    <Button Content="原点操作" Command="{Binding DataContext.CylinderMoveToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="#0F172A" Padding="10,8" Margin="0,0,6,0">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Background" Value="#E6F4EA"/>
                                                                                <Setter Property="BorderBrush" Value="#A7D7B5"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HomeCommandActive}" Value="True">
                                                                                        <Setter Property="Background" Value="#BFE3C8"/>
                                                                                        <Setter Property="BorderBrush" Value="#6FA882"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="动点操作" Command="{Binding DataContext.CylinderMoveToWorkCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="#0F172A" Padding="10,8" Margin="6,0,0,0">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Background" Value="#FFF7DB"/>
                                                                                <Setter Property="BorderBrush" Value="#E9CD76"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding WorkCommandActive}" Value="True">
                                                                                        <Setter Property="Background" Value="#FFE9A8"/>
                                                                                        <Setter Property="BorderBrush" Value="#D0A93A"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </UniformGrid>
                                                                <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,8">
