                                    <Border Style="{StaticResource CardBorderStyle}" Background="#0F172A" Padding="12" Margin="0,0,8,8" Visibility="{Binding IsManualAxisPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="轴单元" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="--" Foreground="#CBD5E1" Margin="0,8,0,12"/><WrapPanel><Button Content="轴使能" Command="{Binding ToggleAxisEnableCommand}" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="报警复位" Command="{Binding AxisAlarmResetCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/></WrapPanel><WrapPanel Margin="0,4,0,8"><TextBlock Text="Jog距离" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Width="80" Text="{Binding AxisJogDistance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/><Button Content="Jog-" Command="{Binding JogAxisNegativeCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,8,0"/><Button Content="Jog+" Command="{Binding JogAxisPositiveCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8"/></WrapPanel><WrapPanel Margin="0,0,0,8"><TextBlock Text="目标位置" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Width="100" Text="{Binding AxisTargetPosition, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/><Button Content="定位移动" Command="{Binding MoveAxisToTargetCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,8,0"/><Button Content="回零" Command="{Binding MoveAxisHomeCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8"/></WrapPanel></StackPanel></Border>
