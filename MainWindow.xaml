                                            <Border Background="#0F766E" CornerRadius="10" Padding="16" Margin="6"><StackPanel><TextBlock Text="生产计数" Foreground="White" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding ProductionCount}" Foreground="#CCFBF1" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/><TextBlock Text="{Binding GoodCount, StringFormat=良品：{0}}" Foreground="#99F6E4" Margin="0,10,0,0" FontSize="12"/><TextBlock Text="{Binding NgCount, StringFormat=NG：{0}}" Foreground="#99F6E4" FontSize="12"/></StackPanel></Border>
