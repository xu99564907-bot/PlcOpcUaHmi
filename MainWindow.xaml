                            <StackPanel>
                                <TextBlock Text="PLC 通讯配置入口" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                <TextBlock Text="通讯参数已从首页移出。请点击右上方的“PLC 通讯配置”按钮，在独立配置窗口中完成 PLC / OPC UA 的 IP、端口、Endpoint 和登录方式设置。" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Button Content="打开 PLC 通讯配置" Click="OpenCommunicationConfigButton_Click" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="12,8" Margin="0,0,8,0"/>
                                    <Button Content="加载通讯配置" Command="{Binding LoadConfigCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,0"/>
                                    <Button Content="保存通讯配置" Command="{Binding SaveConfigCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>                        <DataGrid Grid.Row="2" ItemsSource="{Binding ParametersView}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" RowBackground="#111827" AlternatingRowBackground="#0F172A" RowStyle="{StaticResource ParameterRowStyle}"><DataGrid.Columns><DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="*" IsReadOnly="True"/><DataGridTextColumn Header="参数名" Binding="{Binding Name}" Width="*" IsReadOnly="True"/><DataGridTemplateColumn Header="值" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="White"/></DataTemplate></DataGridTemplateColumn.CellTemplate><DataGridTemplateColumn.CellEditingTemplate><DataTemplate><TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsReadOnly}" Style="{StaticResource DataGridEditTextBoxStyle}"/></DataTemplate></DataGridTemplateColumn.CellEditingTemplate></DataGridTemplateColumn><DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="*" IsReadOnly="True"/><DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/><DataGridTextColumn Header="最小权限" Binding="{Binding MinRole}" Width="*" IsReadOnly="True"/><DataGridTextColumn Header="权限状态" Binding="{Binding PermissionHint}" Width="*" IsReadOnly="True"/></DataGrid.Columns></DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="报警画面">
                    <Grid Margin="12">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12"><DockPanel><StackPanel><TextBlock Text="{Binding CurrentAlarmTitle}" FontSize="20" FontWeight="Bold" Foreground="White"/><TextBlock Text="报警父页面已按左侧子导航切换显示。" Foreground="#94A3B8" Margin="0,8,0,0"/></StackPanel><WrapPanel DockPanel.Dock="Right"><Button Content="确认全部报警" Command="{Binding AcknowledgeAllAlarmsCommand}" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="复位全部报警" Command="{Binding ResetAllAlarmsCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="14,8" Margin="0,0,8,0"/><Button Content="保存报警历史" Command="{Binding SaveAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,8,0"/><Button Content="加载报警历史" Command="{Binding LoadAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8"/></WrapPanel></DockPanel></Border>
                        <Grid Grid.Row="1">
                            <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmCurrentPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="当前报警" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><DataGrid ItemsSource="{Binding CurrentAlarms}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" RowStyle="{StaticResource HighlightRowStyle}"><DataGrid.Columns><DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/><DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/><DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/><DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/><DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/><DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="*"/><DataGridCheckBoxColumn Header="已确认" Binding="{Binding Acknowledged}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                            <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmHistoryPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="历史报警" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><DataGrid ItemsSource="{Binding AlarmHistory}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" RowStyle="{StaticResource HighlightRowStyle}"><DataGrid.Columns><DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/><DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/><DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/><DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/><DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="*"/><DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                            <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmLogPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="日志" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937"><DataGrid.Columns><DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/><DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/><DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/><DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/><DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                            <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmStatisticsPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="报警统计" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><WrapPanel Margin="0,0,0,10"><TextBlock Text="级别：" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/><ComboBox Width="120" ItemsSource="{Binding AlarmLevelOptions}" SelectedItem="{Binding SelectedAlarmLevel}" Margin="0,0,12,0"/><TextBlock Text="时间：" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/><ComboBox Width="120" ItemsSource="{Binding AlarmTimeRangeOptions}" SelectedItem="{Binding SelectedAlarmTimeRange}" Margin="0,0,12,0"/><CheckBox Content="只看重点报警" IsChecked="{Binding ShowOnlyFocusAlarms}" Foreground="White" VerticalAlignment="Center"/></WrapPanel><Border Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="12" Margin="0,0,0,12"><StackPanel><TextBlock Text="重点处理建议" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="{Binding FocusAlarmHint}" Foreground="#FCA5A5" Margin="0,8,0,0" TextWrapping="Wrap"/><TextBlock Text="{Binding EstimatedDowntimeMinutes, StringFormat=预计停机：{0:F1} min}" Foreground="#FCD34D" Margin="0,8,0,0"/><TextBlock Text="{Binding EstimatedProductionLoss, StringFormat=预计影响产量：{0}}" Foreground="#FCA5A5" Margin="0,4,0,0"/></StackPanel></Border><DataGrid ItemsSource="{Binding AlarmStatisticsView}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937"><DataGrid.Columns><DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/><DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/><DataGridTextColumn Header="累计次数" Binding="{Binding Count}" Width="*"/><DataGridTextColumn Header="处理建议" Binding="{Binding HandlingSuggestion}" Width="2*"/><DataGridTemplateColumn Header="联动" Width="*"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="看流程" Command="{Binding DataContext.JumpToFlowByAlarmCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Source}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid></StackPanel></Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="登录权限">
                    <Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,10,0"><StackPanel><TextBlock Text="登录权限" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><TextBlock Text="当前身份" Foreground="#CBD5E1"/><TextBlock Text="{Binding CurrentRoleText}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,4,0,12"/><TextBlock Text="密码" Foreground="#CBD5E1"/><PasswordBox x:Name="RolePasswordBox" PasswordChanged="RolePasswordBox_PasswordChanged" Margin="0,4,0,12"/><WrapPanel><Button Content="操作员" Command="{Binding LoginCommand}" CommandParameter="Operator" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/><Button Content="工程师" Command="{Binding LoginCommand}" CommandParameter="Engineer" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/><Button Content="管理员" Command="{Binding LoginCommand}" CommandParameter="Administrator" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/></WrapPanel><Button Content="退出登录" Command="{Binding LogoutCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="12,8" Width="120"/><TextBlock Text="示例密码：工程师 123456，管理员 admin888" Margin="0,12,0,0" Foreground="#94A3B8" TextWrapping="Wrap"/></StackPanel></Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="16"><StackPanel><TextBlock Text="权限说明" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><TextBlock Text="操作员：查看、监控、设备操作。" Foreground="#CBD5E1" Margin="0,0,0,8"/><TextBlock Text="工程师：可修改大部分工艺与设备参数。" Foreground="#CBD5E1" Margin="0,0,0,8"/><TextBlock Text="管理员：最高权限，可维护系统级参数和报警复位。" Foreground="#CBD5E1" Margin="0,0,0,8"/><TextBlock Text="当前参数页是否允许编辑：" Foreground="#CBD5E1" Margin="0,12,0,4"/><TextBlock Text="{Binding CanEditParameters}" FontSize="24" FontWeight="Bold" Foreground="White"/><TextBlock Text="当前是否允许报警复位：" Foreground="#CBD5E1" Margin="0,12,0,4"/><TextBlock Text="{Binding CanAdmin}" FontSize="24" FontWeight="Bold" Foreground="White"/></StackPanel></Border>
                    </Grid>
                </TabItem>

                <TabItem Header="操作审计">
                    <Grid Margin="12">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12"><StackPanel><TextBlock Text="操作履历审计" FontSize="20" FontWeight="Bold" Foreground="White"/><TextBlock Text="记录登录、确认框、联锁拦截、设备操作、弹窗提示等行为。" Foreground="#94A3B8" Margin="0,8,0,0"/></StackPanel></Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding OperationAudits}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937"><DataGrid.Columns><DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/><DataGridTextColumn Header="用户" Binding="{Binding User}" Width="*"/><DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="*"/><DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="*"/><DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*"/><DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="2*"/></DataGrid.Columns></DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="设计器">
                    <Grid Margin="12" Visibility="{Binding IsDesignMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="页面与工具箱" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><TextBlock Text="工程名称" Foreground="#CBD5E1"/><TextBox Text="{Binding DesignerProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="当前页面" Foreground="#CBD5E1"/><ComboBox ItemsSource="{Binding DesignerPages}" SelectedItem="{Binding SelectedDesignerPage}" Margin="0,4,0,8"/><WrapPanel Margin="0,0,0,8"><Button Content="新建页面" Command="{Binding AddNewPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/><Button Content="删除页面" Command="{Binding RemoveCurrentPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/><Button Content="加载工程" Command="{Binding LoadDesignerProjectCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="运行页模板" Foreground="#CBD5E1"/><ComboBox ItemsSource="{Binding RuntimeTemplates}" SelectedItem="{Binding SelectedRuntimeTemplate}" Margin="0,4,0,8"/><Button Content="应用模板" Command="{Binding ApplyRuntimeTemplateCommand}" CommandParameter="{Binding SelectedRuntimeTemplate}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,0,8"/><TextBlock Text="页面名称" Foreground="#CBD5E1"/><TextBox Text="{Binding DesignerPageName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="画布尺寸" Foreground="#CBD5E1"/><UniformGrid Columns="2" Margin="0,4,0,8"><TextBox Text="{Binding DesignerCanvasWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><TextBox Text="{Binding DesignerCanvasHeight, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0"/></UniformGrid><TextBlock Text="工具箱" Foreground="#CBD5E1" Margin="0,0,0,8"/></StackPanel><ItemsControl ItemsSource="{Binding ToolboxItems}"><ItemsControl.ItemTemplate><DataTemplate><Button Content="{Binding}" Command="{Binding DataContext.AddDesignerElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,0,8" Padding="10" Background="#1F2937" Foreground="White" BorderBrush="#334155" PreviewMouseMove="ToolboxItem_PreviewMouseMove"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></DockPanel></Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,10"><TextBlock Text="设计画布" FontSize="18" FontWeight="Bold" Foreground="White"/><TextBlock DockPanel.Dock="Right" Text="仅设计态可编辑" Foreground="#94A3B8"/></DockPanel><ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"><Canvas x:Name="DesignerCanvas" Width="{Binding DesignerCanvasWidth}" Height="{Binding DesignerCanvasHeight}" Background="#0F172A" ClipToBounds="True" AllowDrop="True" DragOver="DesignerCanvas_DragOver" Drop="DesignerCanvas_Drop"><ItemsControl ItemsSource="{Binding DesignerElements}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="{Binding Left}"/><Setter Property="Canvas.Top" Value="{Binding Top}"/></Style></ItemsControl.ItemContainerStyle><ItemsControl.Resources><DataTemplate DataType="{x:Type model:DesignerElement}"><Border Width="{Binding Width}" Height="{Binding Height}" Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}" BorderBrush="{Binding BorderBrush, Converter={StaticResource StringToBrushConverter}}" BorderThickness="2" CornerRadius="8" behavior:DragCanvasBehavior.EnableDrag="True"><Button Command="{Binding DataContext.SelectDesignerElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0"><Grid><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="{Binding ElementType}" FontSize="10" Foreground="#E2E8F0" HorizontalAlignment="Center"/><TextBlock Text="{Binding Text}" FontSize="{Binding FontSize}" FontWeight="SemiBold" Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}" HorizontalAlignment="Center" TextWrapping="Wrap"/></StackPanel></Grid></Button></Border></DataTemplate></ItemsControl.Resources></ItemsControl></Canvas></ScrollViewer></Grid></Border>
                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock Text="属性编辑器" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/><WrapPanel Margin="0,0,0,10"><Button Content="删除" Command="{Binding RemoveSelectedDesignerElementCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="10,6" Margin="0,0,6,6"/><Button Content="复制" Command="{Binding CopySelectedDesignerElementCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/><Button Content="粘贴" Command="{Binding PasteDesignerElementCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="名称" Foreground="#CBD5E1"/><TextBox Text="{Binding SelectedDesignerElement.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="类型" Foreground="#CBD5E1"/><TextBox Text="{Binding SelectedDesignerElement.ElementType, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="显示文本" Foreground="#CBD5E1"/><TextBox Text="{Binding SelectedDesignerElement.Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="变量绑定" Foreground="#CBD5E1"/><TextBox Text="{Binding SelectedDesignerElement.TagBinding, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/></StackPanel></ScrollViewer></Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#111827" BorderBrush="#1F2937" BorderThickness="1,1,0,0" Padding="12,6">
            <DockPanel>
                <WrapPanel>
                    <Border Background="#7C3AED" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <TextBlock Text="{Binding DesignerModeText}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#065F46" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <TextBlock Text="{Binding CurrentRoleText}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding SystemMessage}" Foreground="White" VerticalAlignment="Center"/>
                </WrapPanel>
                <TextBlock DockPanel.Dock="Right" Text="C# / WPF / OPC UA / HMI Designer" Foreground="#94A3B8" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>








