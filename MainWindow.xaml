                                </UniformGrid>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="12" Margin="0,0,0,12"><StackPanel><TextBlock Text="历史趋势落盘状态" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="系统每次刷新时会自动将 OEE / 产量 / 报警数追加写入 trend-history.csv。" Foreground="#CBD5E1" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                <Grid Margin="0,12,0,0">
