                                    <Border Style="{StaticResource CardBorderStyle}" Background="#0F172A" Padding="12" Margin="0,0,8,8"><StackPanel><TextBlock Text="班次状态" Foreground="#94A3B8"/><TextBlock Text="{Binding ShiftStatusText}" FontSize="20" FontWeight="Bold" Foreground="White"/></StackPanel></Border>
