                                            <Border Background="#B91C1C" CornerRadius="10" Padding="16" Margin="6"><StackPanel><TextBlock Text="运行日志" Foreground="White" FontSize="18" FontWeight="Bold"/><TextBlock Text="{Binding Logs[0].Message}" Foreground="#FEE2E2" Margin="0,6,0,0" TextWrapping="Wrap"/><TextBlock Text="最近一条系统日志" Foreground="#FECACA" Margin="0,10,0,0" FontSize="12"/></StackPanel></Border>
