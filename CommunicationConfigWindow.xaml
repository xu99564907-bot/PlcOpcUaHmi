<Window x:Class="PlcOpcUaHmi.CommunicationConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC 通讯配置"
        Height="430"
        Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="PLC / OPC UA 通讯参数"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#0F172A"/>
            <TextBlock Text="在这里统一设置通讯协议、服务器地址、端口、Endpoint 和登录方式。"
                       Foreground="#64748B"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#D7DFEA"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Margin="0,16,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="通讯协议"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"/>
                <ComboBox Grid.Column="1"
                          Grid.ColumnSpan="3"
                          ItemsSource="{Binding CommunicationProtocolOptions}"
                          SelectedItem="{Binding Connection.Protocol, UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1"
                           Text="服务器 IP"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding Connection.ServerIp, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,10"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="端口"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"/>
                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Text="{Binding Connection.Port, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2"
                           Text="Endpoint"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"/>
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         Text="{Binding Connection.EndpointPath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <CheckBox Grid.Row="3"
                          Grid.ColumnSpan="2"
                          Content="匿名连接"
                          IsChecked="{Binding Connection.UseAnonymous}"
                          Foreground="#0F172A"
                          Margin="0,0,0,10"/>

                <TextBlock Grid.Row="4"
                           Text="用户名"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           Margin="0,0,8,10"/>
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         Text="{Binding Connection.Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connection.UseAnonymous}" Value="False">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Grid.Row="5"
                           Text="密码"
                           Foreground="#475569"
                           VerticalAlignment="Center"/>
                <PasswordBox x:Name="ConnectionPasswordBox"
                             Grid.Row="5"
                             Grid.Column="1"
                             Grid.ColumnSpan="3"
                             PasswordChanged="ConnectionPasswordBox_PasswordChanged">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Connection.UseAnonymous}" Value="False">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2">
            <TextBlock Text="保存后会写入软件根目录下的 config/appsettings.json"
                       Foreground="#64748B"
                       VerticalAlignment="Center"/>
            <WrapPanel DockPanel.Dock="Right">
                <Button Content="加载通讯配置"
                        Command="{Binding LoadConfigCommand}"
                        Background="#E2E8F0"
                        Foreground="#0F172A"
                        BorderBrush="#CBD5E1"
                        Padding="12,8"
                        Margin="0,0,8,0"/>
                <Button Content="保存通讯配置"
                        Command="{Binding SaveConfigCommand}"
                        Background="#0F766E"
                        Foreground="White"
                        BorderBrush="#0F766E"
                        Padding="12,8"
                        Margin="0,0,8,0"/>
                <Button Content="关闭"
                        Click="CloseButton_Click"
                        Background="#E2E8F0"
                        Foreground="#0F172A"
                        BorderBrush="#CBD5E1"
                        Padding="12,8"/>
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
